<Window x:Class="DegrandeScreenShot.App.GalleryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screenshot Gallery"
        Width="1120"
        Height="760"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource GalleryBackgroundBrush}"
        Foreground="{DynamicResource GalleryTextBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="GalleryBackgroundBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="GalleryHeaderBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="GalleryCardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="GalleryBorderBrush" Color="#D5E0EA" />
        <SolidColorBrush x:Key="GalleryTextBrush" Color="#1D2631" />
        <SolidColorBrush x:Key="GalleryMutedTextBrush" Color="#6C7987" />
        <SolidColorBrush x:Key="GalleryAccentBrush" Color="#0A6F9A" />
        <SolidColorBrush x:Key="GalleryAccentBorderBrush" Color="#0C8EC5" />
        <SolidColorBrush x:Key="GalleryAccentSubtleBrush" Color="#EAF4FA" />
        <SolidColorBrush x:Key="GalleryActionHoverBrush" Color="#EAF4FA" />
        <SolidColorBrush x:Key="GalleryThumbnailBackdropBrush" Color="#E3E9EF" />

        <Style x:Key="GalleryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource GalleryCardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource GalleryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GalleryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GalleryActionHoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource GalleryAccentBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThumbnailButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource GalleryCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GalleryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource GalleryAccentBorderBrush}" />
                                <Setter TargetName="Card" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#33006A93" BlurRadius="14" ShadowDepth="3" Opacity="0.7" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource GalleryHeaderBrush}" BorderBrush="{DynamicResource GalleryBorderBrush}" BorderThickness="0,0,0,1" Padding="28,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Screenshot Gallery"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource GalleryTextBrush}" />
                    <TextBlock x:Name="LibraryPathText"
                               Margin="0,5,0,0"
                               Foreground="{DynamicResource GalleryMutedTextBrush}"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Open folder"
                            Margin="0,0,10,0"
                            Style="{StaticResource GalleryActionButtonStyle}"
                            Click="OpenFolder_Click" />
                    <Button Content="Refresh"
                            Style="{StaticResource GalleryActionButtonStyle}"
                            Click="Refresh_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="GalleryScroll"
                      Grid.Row="1"
                      Padding="28,24,12,28"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="DayGroupsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="{Binding Header}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource GalleryTextBrush}" />
                                <Border Margin="10,3,0,0"
                                        Padding="8,2"
                                        Background="{DynamicResource GalleryAccentSubtleBrush}"
                                        CornerRadius="8"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Count}"
                                               FontSize="12"
                                               Foreground="{DynamicResource GalleryAccentBrush}" />
                                </Border>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding Screenshots}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="240"
                                                Height="210"
                                                Style="{StaticResource ThumbnailButtonStyle}"
                                                Tag="{Binding}"
                                                Click="Screenshot_Click"
                                                ToolTip="Open in a new editor window">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="156" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Border Background="{DynamicResource GalleryThumbnailBackdropBrush}" CornerRadius="11,11,0,0" ClipToBounds="True">
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Border>
                                                <Grid Grid.Row="1" Margin="12,8,12,9">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource GalleryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding TimeText}"
                                                                   Margin="0,2,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource GalleryMutedTextBrush}" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="&#xE8A7;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="14"
                                                               Foreground="{DynamicResource GalleryAccentBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0,0,0" />
                                                </Grid>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel x:Name="EmptyState"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
            <Border Width="72" Height="72" Background="{DynamicResource GalleryAccentSubtleBrush}" CornerRadius="36" HorizontalAlignment="Center">
                <TextBlock Text="&#xE91B;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="30"
                           Foreground="{DynamicResource GalleryAccentBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="No screenshots yet"
                       Margin="0,18,0,0"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource GalleryTextBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="New captures will appear here automatically."
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource GalleryMutedTextBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
