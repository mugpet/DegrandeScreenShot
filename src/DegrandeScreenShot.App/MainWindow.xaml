<Window x:Class="DegrandeScreenShot.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Degrande ScreenShot"
        Width="500"
        Height="720"
        MinWidth="500"
        MinHeight="720"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#E8ECE5"
        ShowInTaskbar="True">
    <Grid Background="#E8ECE5">
        <Border Margin="14"
                Padding="20"
                Background="#F7FAF6"
                BorderBrush="#D8DFD9"
                BorderThickness="1"
                CornerRadius="24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="10" Color="#22000000" Opacity="0.28" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Padding="18"
                    MouseLeftButtonDown="DragSurface_MouseLeftButtonDown"
                        Background="#1A2A26"
                        CornerRadius="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="14" Foreground="#A8C3B9" Text="Quick capture" />
                            <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Foreground="White" Text="Degrande ScreenShot" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#D3DEDA"
                                       FontSize="13"
                                       Text="A popup-style launcher for region capture, clipboard copy, and editor handoff across all monitors."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Width="32"
                                Height="32"
                                Margin="12,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Click="CloseWindow_Click"
                                Background="#1FFFFFFF"
                                BorderBrush="#2FFFFFFF"
                                BorderThickness="1"
                                Foreground="White"
                                Content="X" />
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,18,0,0" Orientation="Horizontal">
                    <Button Width="176"
                            Click="StartCapture_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Capture Region" />
                    <Button Width="138"
                            Margin="10,0,0,0"
                            Click="OpenEditorDemo_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Demo Editor" />
                </StackPanel>

                <Border Grid.Row="2"
                        Margin="0,18,0,0"
                        Padding="16"
                        Background="#EFF4EF"
                        BorderBrush="#D8DFD9"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Default controls" />
                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" Text="Drag to select. Hold Shift for 1:1, Ctrl to move the frame, arrows to nudge 1 px, Esc to cancel." TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="3" Margin="0,20,0,0" FontSize="18" FontWeight="SemiBold" Text="Shortcuts" />

                <ScrollViewer Grid.Row="4"
                              Margin="0,12,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Margin="0,0,0,12" Padding="16" Background="White" BorderBrush="#D8DFD9" BorderThickness="1" CornerRadius="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Padding="10,6" Background="#E8F2EF" CornerRadius="12">
                                    <TextBlock FontWeight="SemiBold" Foreground="#125B50" Text="Ctrl + Shift + 4" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock FontWeight="SemiBold" Text="Capture with chooser" />
                                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" Text="Freeze all monitors, draw a region, then choose whether to copy it or open it in the editor." TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Margin="0,0,0,12" Padding="16" Background="White" BorderBrush="#D8DFD9" BorderThickness="1" CornerRadius="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Padding="10,6" Background="#F1F5EA" CornerRadius="12">
                                    <TextBlock FontWeight="SemiBold" Foreground="#556B2F" Text="Ctrl + Shift + Alt + 5" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock FontWeight="SemiBold" Text="Region, then decide" />
                                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" Text="Start region capture directly from the keyboard and keep the post-capture choice visible after selection." TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Margin="0,0,0,12" Padding="16" Background="White" BorderBrush="#D8DFD9" BorderThickness="1" CornerRadius="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Padding="10,6" Background="#FDF3E7" CornerRadius="12">
                                    <TextBlock FontWeight="SemiBold" Foreground="#A85B1A" Text="Ctrl + Shift + Alt + 6" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock FontWeight="SemiBold" Text="Region straight to clipboard" />
                                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" Text="Freeze the desktop, draw a region, and send the result straight to the clipboard with no extra prompt." TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Padding="16" Background="White" BorderBrush="#D8DFD9" BorderThickness="1" CornerRadius="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Padding="10,6" Background="#EDEAF7" CornerRadius="12">
                                    <TextBlock FontWeight="SemiBold" Foreground="#5E4D91" Text="Ctrl + Shift + Alt + 7" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock FontWeight="SemiBold" Text="Region straight to editor" />
                                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" Text="Freeze the desktop, draw a region, and open the result in the annotation editor immediately." TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Grid.Row="5"
                           Margin="0,18,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12"
                           Text="The launcher opens near the taskbar so it behaves more like a quick popup than a full landing page."
                           TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
