                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Data="M2.2,9.5 C4.3,5.3 6.2,13.2 8.3,8.2 C9.5,5.1 11.5,5.4 13.8,7" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Grid>
                                        </ToggleButton>
                                        <Popup x:Name="HighlightModePopup"
                                               PlacementTarget="{Binding ElementName=HighlightToolButton}"
                                               Placement="Top"
                                               VerticalOffset="-10"
                                               AllowsTransparency="True"
                                               PopupAnimation="Fade"
                                               StaysOpen="False">
                                            <Border Padding="14"
                                                    CornerRadius="18"
                                                    Background="{DynamicResource PopupPanelBackgroundBrush}"
                                                    BorderBrush="{DynamicResource PopupPanelBorderBrush}"
                                                    BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Width="44"
                                                            Height="44"
                                                            Padding="0"
                                                            Tag="Region"
                                                            Click="HighlightModeOption_Click"
                                                            Style="{StaticResource EditorTopBarButtonStyle}"
                                                            ToolTip="Area highlight">
                                                        <Viewbox Width="18" Height="18">
                                                            <Canvas Width="16" Height="16">
                                                                <Rectangle Width="11.5" Height="7.5" Canvas.Left="2.25" Canvas.Top="4.25"
                                                                           RadiusX="2"
                                                                           RadiusY="2"
                                                                           Fill="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                                           Opacity="0.24" />
                                                                <Rectangle Width="11.5" Height="7.5" Canvas.Left="2.25" Canvas.Top="4.25"
                                                                           RadiusX="2"
                                                                           RadiusY="2"
                                                                           Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                                           StrokeThickness="1.5" />
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Button>
                                                    <Button Width="44"
                                                            Height="44"
                                                            Margin="8,0,0,0"
                                                            Padding="0"
                                                            Tag="Line"
                                                            Click="HighlightModeOption_Click"
                                                            Style="{StaticResource EditorTopBarButtonStyle}"
                                                            ToolTip="Line highlight">
                                                        <Viewbox Width="18" Height="18">
                                                            <Canvas Width="16" Height="16">
                                                                <Line X1="2.5" Y1="8" X2="13.5" Y2="8"
                                                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                                      StrokeThickness="5"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      Opacity="0.25" />
                                                                <Line X1="2.5" Y1="8" X2="13.5" Y2="8"
                                                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                                      StrokeThickness="1.8"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round" />
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Button>
                                                    <Button Width="44"
                                                            Height="44"
                                                            Margin="8,0,0,0"
                                                            Padding="0"
                                                            Tag="Freehand"
                                                            Click="HighlightModeOption_Click"
                                                            Style="{StaticResource EditorTopBarButtonStyle}"
                                                            ToolTip="Freehand highlight">
                                                        <Viewbox Width="18" Height="18">
                                                            <Canvas Width="16" Height="16">
                                                                <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                                      StrokeThickness="5"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      StrokeLineJoin="Round"
                                                                      Opacity="0.25"
                                                                      Data="M2.2,9.5 C4.3,5.3 6.2,13.2 8.3,8.2 C9.5,5.1 11.5,5.4 13.8,7" />
                                                                <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                                      StrokeThickness="1.8"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      StrokeLineJoin="Round"
                                                                      Data="M2.2,9.5 C4.3,5.3 6.2,13.2 8.3,8.2 C9.5,5.1 11.5,5.4 13.8,7" />
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                        <ToggleButton x:Name="TextToolButton" Margin="8,0,0,0" Style="{StaticResource EditorTopBarToolButtonStyle}" Checked="ToolButton_Checked" Tag="Text" ToolTip="Text">
                                            <TextBlock FontSize="18"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                       Text="T" />
                                        </ToggleButton>
                                    </StackPanel>

                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="14,0,0,0">
                                        <Border Width="1" Height="26" Margin="0,9,14,9" Background="{DynamicResource IslandDividerBrush}" CornerRadius="1" />
                                        <Button x:Name="UndoHistoryButton" Click="UndoHistory_Click" Style="{StaticResource EditorTopBarButtonStyle}" ToolTip="Undo (Ctrl+Z)">
                                            <TextBlock Style="{StaticResource EditorGlyphStyle}" FontSize="18" Margin="0" Text="&#xE7A7;" />
                                        </Button>
                                        <Button x:Name="RedoHistoryButton" Margin="8,0,0,0" Click="RedoHistory_Click" Style="{StaticResource EditorTopBarButtonStyle}" ToolTip="Redo (Ctrl+Y)">
                                            <TextBlock Style="{StaticResource EditorGlyphStyle}" FontSize="18" Margin="0" Text="&#xE7A6;" />
                                        </Button>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>