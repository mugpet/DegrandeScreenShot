<Window x:Class="DegrandeScreenShot.App.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Capture"
        Width="850"
        Height="400"
        MinWidth="850"
        MinHeight="400"
        Background="{DynamicResource ShellBackgroundBrush}"
        PreviewKeyDown="EditorWindow_PreviewKeyDown"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#111418" />
        <SolidColorBrush x:Key="EditorWorkspaceBrush" Color="#161A20" />
        <SolidColorBrush x:Key="EditorCanvasBrush" Color="#2A3039" />
        <SolidColorBrush x:Key="IslandBackgroundBrush" Color="#D91A1E25" />
        <SolidColorBrush x:Key="IslandBorderBrush" Color="#28FFFFFF" />
        <SolidColorBrush x:Key="IslandButtonBrush" Color="#12FFFFFF" />
        <SolidColorBrush x:Key="IslandButtonHoverBrush" Color="#1CFFFFFF" />
        <SolidColorBrush x:Key="IslandButtonPressedBrush" Color="#26FFFFFF" />
        <SolidColorBrush x:Key="IslandButtonActiveBrush" Color="#FF1AA9D8" />
        <SolidColorBrush x:Key="IslandButtonActiveBorderBrush" Color="#7DCCF3FF" />
        <SolidColorBrush x:Key="IslandTextBrush" Color="#FFF4F7FB" />
        <SolidColorBrush x:Key="IslandMutedTextBrush" Color="#A9C2CEDA" />
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#FF1AA9D8" />
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#7DCCF3FF" />
        <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#FF34BCE6" />
        <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#FF1498C6" />
        <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#18FFFFFF" />
        <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#1FFFFFFF" />
        <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="SecondaryButtonPressedBrush" Color="#2BFFFFFF" />
        <SolidColorBrush x:Key="FloatingCardBrush" Color="#D9161A20" />
        <SolidColorBrush x:Key="FloatingCardBorderBrush" Color="#2BFFFFFF" />
        <SolidColorBrush x:Key="ShellScrimBrush" Color="#09000000" />
        <SolidColorBrush x:Key="ShellTopHighlightBrush" Color="#12FFFFFF" />
        <SolidColorBrush x:Key="InlineTextInputBackgroundBrush" Color="#D91A1E25" />
        <SolidColorBrush x:Key="InlineTextInputBorderBrush" Color="#66CCF3FF" />
        <SolidColorBrush x:Key="InlineTextInputForegroundBrush" Color="#FFF4F7FB" />
        <SolidColorBrush x:Key="PopupPanelBackgroundBrush" Color="#F0181C22" />
        <SolidColorBrush x:Key="PopupPanelBorderBrush" Color="#26FFFFFF" />
        <SolidColorBrush x:Key="DeleteButtonBackgroundBrush" Color="#3AD94841" />
        <SolidColorBrush x:Key="DeleteButtonBorderBrush" Color="#80FFB0AA" />
        <SolidColorBrush x:Key="DeleteButtonForegroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="IslandDividerBrush" Color="#1FFFFFFF" />
        <LinearGradientBrush x:Key="ShellGlowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#44FFB86C" Offset="0" />
            <GradientStop Color="#14FF7A00" Offset="0.4" />
            <GradientStop Color="#00000000" Offset="0.9" />
        </LinearGradientBrush>

        <Style x:Key="EditorPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#6600C8FF" Opacity="0.45" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Storyboard x:Key="ButtonGrowStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.18" />
                </Storyboard>
                <Storyboard x:Key="ButtonResetStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18" />
                </Storyboard>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryButtonPressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard Storyboard="{StaticResource ButtonGrowStoryboard}" />
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard Storyboard="{StaticResource ButtonResetStoryboard}" />
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource IslandTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SecondaryButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Storyboard x:Key="SecondaryButtonGrowStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.04" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.04" Duration="0:0:0.18" />
                </Storyboard>
                <Storyboard x:Key="SecondaryButtonResetStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18" />
                </Storyboard>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryButtonPressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard Storyboard="{StaticResource SecondaryButtonGrowStoryboard}" />
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard Storyboard="{StaticResource SecondaryButtonResetStoryboard}" />
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorTopBarButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorSecondaryButtonStyle}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource IslandButtonBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
            <Setter Property="Foreground" Value="{DynamicResource IslandTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IslandButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IslandButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorTopBarPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorTopBarButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource IslandButtonActiveBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource IslandButtonActiveBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="EditorTopBarToolButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{DynamicResource IslandButtonBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource IslandTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Storyboard x:Key="ToolGrowStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.08" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.08" Duration="0:0:0.18" />
                </Storyboard>
                <Storyboard x:Key="ToolResetStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18" />
                </Storyboard>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IslandButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IslandButtonActiveBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource IslandButtonActiveBorderBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard Storyboard="{StaticResource ToolGrowStoryboard}" />
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard Storyboard="{StaticResource ToolResetStoryboard}" />
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorIconLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource IslandTextBrush}" />
        </Style>

        <Style x:Key="EditorGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}" />
        </Style>

        <Style x:Key="EditorGlyphStackStyle" TargetType="TextBlock" BasedOn="{StaticResource EditorGlyphStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="EditorIconLabelCenteredStyle" TargetType="TextBlock" BasedOn="{StaticResource EditorIconLabelStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="FloatingCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource FloatingCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FloatingCardBorderBrush}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Color="#99000000" Opacity="0.34" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="EditorRootGrid" Background="{DynamicResource ShellBackgroundBrush}">
        <Rectangle Fill="{DynamicResource ShellGlowBrush}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Top"
                   Height="260"
                   IsHitTestVisible="False"
                   Opacity="0.95" />

        <Border Margin="0"
                Padding="0"
                CornerRadius="0"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#CC000000" Opacity="0.5" />
            </Border.Effect>

            <Border CornerRadius="0"
                    Background="{DynamicResource EditorWorkspaceBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    SnapsToDevicePixels="True">
                <Grid ClipToBounds="True">
                    <Rectangle Fill="{DynamicResource ShellScrimBrush}" IsHitTestVisible="False" />
                    <Rectangle Fill="{DynamicResource ShellTopHighlightBrush}"
                               Height="140"
                               VerticalAlignment="Top"
                               IsHitTestVisible="False">
                        <Rectangle.OpacityMask>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFFFFFFF" Offset="0" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.OpacityMask>
                    </Rectangle>

                    <ScrollViewer x:Name="ArtworkScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent"
                                  PreviewMouseWheel="ArtworkScrollViewer_PreviewMouseWheel"
                                  ScrollChanged="ArtworkScrollViewer_ScrollChanged">
                        <Grid MinWidth="{Binding ElementName=ArtworkScrollViewer, Path=ViewportWidth}"
                              MinHeight="{Binding ElementName=ArtworkScrollViewer, Path=ViewportHeight}">
                            <Border Margin="0,0,0,136"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CornerRadius="0">
                                <Grid x:Name="ArtworkZoomHost"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">
                                    <Grid.LayoutTransform>
                                        <ScaleTransform x:Name="ArtworkZoomTransform" ScaleX="1" ScaleY="1" />
                                    </Grid.LayoutTransform>

                                    <Grid x:Name="ArtworkSurface"
                                          Background="Transparent"
                                          ClipToBounds="True"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top">
                                        <Image x:Name="BaseImage"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top"
                                               Stretch="None" />
                                        <Canvas x:Name="AnnotationCanvas"
                                                ClipToBounds="True"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Background="Transparent"
                                                MouseLeftButtonDown="AnnotationCanvas_MouseLeftButtonDown"
                                                MouseRightButtonDown="AnnotationCanvas_MouseRightButtonDown"
                                                MouseMove="AnnotationCanvas_MouseMove"
                                                MouseLeftButtonUp="AnnotationCanvas_MouseLeftButtonUp"
                                                MouseLeave="AnnotationCanvas_MouseLeave" />

                                        <Popup x:Name="InlineTextPopup"
                                               AllowsTransparency="True"
                                               Placement="RelativePoint"
                                               PlacementTarget="{Binding ElementName=AnnotationCanvas}"
                                               StaysOpen="True">
                                            <Grid>
                                                <Rectangle x:Name="InlineTextBackdrop"
                                                           RadiusX="12"
                                                           RadiusY="12"
                                                           IsHitTestVisible="False">
                                                    <Rectangle.Effect>
                                                        <BlurEffect Radius="16" RenderingBias="Quality" />
                                                    </Rectangle.Effect>
                                                </Rectangle>
                                                <Border x:Name="InlineTextEditorBorder"
                                                        Padding="3"
                                                        Background="{DynamicResource InlineTextInputBackgroundBrush}"
                                                        BorderBrush="{DynamicResource InlineTextInputBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <TextBox x:Name="InlineTextEditor"
                                                             MinWidth="160"
                                                             MaxWidth="340"
                                                             MinHeight="46"
                                                             Padding="12,8"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             Foreground="{DynamicResource InlineTextInputForegroundBrush}"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             VerticalScrollBarVisibility="Hidden"
                                                             PreviewKeyDown="InlineTextEditor_PreviewKeyDown"
                                                             TextChanged="InlineTextEditor_TextChanged"
                                                             LostKeyboardFocus="InlineTextEditor_LostKeyboardFocus" />
                                                </Border>
                                            </Grid>
                                        </Popup>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>

                    <Border x:Name="SelectionActionIsland"
                            Visibility="Collapsed"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="0"
                            Padding="10"
                            Panel.ZIndex="20"
                            Background="{DynamicResource IslandBackgroundBrush}"
                            BorderBrush="{DynamicResource IslandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="34" ShadowDepth="12" Color="#CC000000" Opacity="0.46" />
                        </Border.Effect>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="SelectionActionIslandTransform" />
                        </Border.RenderTransform>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Width="26" Height="26" Margin="0,0,6,0" Padding="0" BorderThickness="0" Background="Transparent" Click="ColorOption_Click" Tag="#0A7A68">
                                    <Border Width="20" Height="20" Background="#0A7A68" BorderBrush="White" BorderThickness="2" CornerRadius="10" />
                                </Button>
                                <Button Width="26" Height="26" Margin="0,0,6,0" Padding="0" BorderThickness="0" Background="Transparent" Click="ColorOption_Click" Tag="#F08C00">
                                    <Border Width="20" Height="20" Background="#F08C00" BorderBrush="White" BorderThickness="2" CornerRadius="10" />
                                </Button>
                                <Button Width="26" Height="26" Margin="0,0,6,0" Padding="0" BorderThickness="0" Background="Transparent" Click="ColorOption_Click" Tag="#D94841">
                                    <Border Width="20" Height="20" Background="#D94841" BorderBrush="White" BorderThickness="2" CornerRadius="10" />
                                </Button>
                                <Button Width="26" Height="26" Margin="0,0,6,0" Padding="0" BorderThickness="0" Background="Transparent" Click="ColorOption_Click" Tag="#7C3AED">
                                    <Border Width="20" Height="20" Background="#7C3AED" BorderBrush="White" BorderThickness="2" CornerRadius="10" />
                                </Button>
                                <Button Width="26" Height="26" Margin="0,0,6,0" Padding="0" BorderThickness="0" Background="Transparent" Click="ColorOption_Click" Tag="#2563EB">
                                    <Border Width="20" Height="20" Background="#2563EB" BorderBrush="White" BorderThickness="2" CornerRadius="10" />
                                </Button>
                                <Button Width="26" Height="26" Margin="0,0,8,0" Padding="0" BorderThickness="0" Background="Transparent" Click="ColorOption_Click" Tag="#111827">
                                    <Border Width="20" Height="20" Background="#111827" BorderBrush="White" BorderThickness="2" CornerRadius="10" />
                                </Button>
                            </StackPanel>
                            <StackPanel x:Name="TextSizePanel" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                                <Border Width="1" Height="24" Margin="0,0,10,0" Background="{DynamicResource IslandDividerBrush}" CornerRadius="1" />
                                <Button Width="34" Height="28" Margin="0,0,6,0" Padding="0" Click="TextSizeOption_Click" Style="{StaticResource EditorSecondaryButtonStyle}" Tag="18" ToolTip="Small text">
                                    <Viewbox Width="16" Height="16">
                                        <Grid Width="16" Height="16">
                                            <TextBlock Text="T" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Top" />
                                            <Rectangle Width="10" Height="1.5" RadiusX="0.75" RadiusY="0.75" Fill="{DynamicResource IslandTextBrush}" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,2" />
                                        </Grid>
                                    </Viewbox>
                                </Button>
                                <Button Width="34" Height="28" Margin="0,0,6,0" Padding="0" Click="TextSizeOption_Click" Style="{StaticResource EditorSecondaryButtonStyle}" Tag="26" ToolTip="Medium text">
                                    <Viewbox Width="16" Height="16">
                                        <Grid Width="16" Height="16">
                                            <TextBlock Text="T" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Top" />
                                            <Rectangle Width="10" Height="1.5" RadiusX="0.75" RadiusY="0.75" Fill="{DynamicResource IslandTextBrush}" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,2" />
                                        </Grid>
                                    </Viewbox>
                                </Button>
                                <Button Width="34" Height="28" Margin="0,0,6,0" Padding="0" Click="TextSizeOption_Click" Style="{StaticResource EditorSecondaryButtonStyle}" Tag="34" ToolTip="Large text">
                                    <Viewbox Width="16" Height="16">
                                        <Grid Width="16" Height="16">
                                            <TextBlock Text="T" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Top" />
                                            <Rectangle Width="10" Height="1.5" RadiusX="0.75" RadiusY="0.75" Fill="{DynamicResource IslandTextBrush}" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,2" />
                                        </Grid>
                                    </Viewbox>
                                </Button>
                                <Button Width="34" Height="28" Padding="0" Click="TextSizeOption_Click" Style="{StaticResource EditorSecondaryButtonStyle}" Tag="42" ToolTip="Extra large text">
                                    <Viewbox Width="16" Height="16">
                                        <Grid Width="16" Height="16">
                                            <TextBlock Text="T" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Top" />
                                            <Rectangle Width="10" Height="1.5" RadiusX="0.75" RadiusY="0.75" Fill="{DynamicResource IslandTextBrush}" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,2" />
                                        </Grid>
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                            <StackPanel x:Name="TextBackgroundOpacityPanel" Orientation="Horizontal" Margin="10,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                <Border Width="1" Height="24" Margin="0,0,10,0" Background="{DynamicResource IslandDividerBrush}" CornerRadius="1" />
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="Text bg" VerticalAlignment="Center" />
                                <Slider x:Name="TextBackgroundOpacitySlider"
                                        Width="120"
                                        Margin="8,0,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="False"
                                        SmallChange="1"
                                        LargeChange="10"
                                        VerticalAlignment="Center"
                                        ValueChanged="TextBackgroundOpacitySlider_ValueChanged" />
                                <TextBlock x:Name="TextBackgroundOpacityValueText"
                                           Margin="8,0,0,0"
                                           Foreground="{DynamicResource IslandMutedTextBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Text="80%" />
                            </StackPanel>
                            <StackPanel x:Name="TextBackgroundStrengthPanel" Orientation="Horizontal" Margin="10,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                <Border Width="1" Height="24" Margin="0,0,10,0" Background="{DynamicResource IslandDividerBrush}" CornerRadius="1" />
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="Bg color" VerticalAlignment="Center" />
                                <Slider x:Name="TextBackgroundStrengthSlider"
                                        Width="120"
                                        Margin="8,0,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="False"
                                        SmallChange="1"
                                        LargeChange="10"
                                        VerticalAlignment="Center"
                                        ValueChanged="TextBackgroundStrengthSlider_ValueChanged" />
                                <TextBlock x:Name="TextBackgroundStrengthValueText"
                                           Margin="8,0,0,0"
                                           Foreground="{DynamicResource IslandMutedTextBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Text="30%" />
                            </StackPanel>
                            <StackPanel x:Name="ObscureBlurLevelPanel" Orientation="Horizontal" Margin="10,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                <Border Width="1" Height="24" Margin="0,0,10,0" Background="{DynamicResource IslandDividerBrush}" CornerRadius="1" />
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="Blur" VerticalAlignment="Center" />
                                <Slider x:Name="ObscureBlurLevelSlider"
                                        Width="120"
                                        Margin="8,0,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="False"
                                        SmallChange="1"
                                        LargeChange="10"
                                        VerticalAlignment="Center"
                                        ValueChanged="ObscureBlurLevelSlider_ValueChanged" />
                                <TextBlock x:Name="ObscureBlurLevelValueText"
                                           Margin="8,0,0,0"
                                           Foreground="{DynamicResource IslandMutedTextBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Text="72%" />
                            </StackPanel>
                            <StackPanel x:Name="ObscurePixelationLevelPanel" Orientation="Horizontal" Margin="10,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                <Border Width="1" Height="24" Margin="0,0,10,0" Background="{DynamicResource IslandDividerBrush}" CornerRadius="1" />
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="Pixelate" VerticalAlignment="Center" />
                                <Slider x:Name="ObscurePixelationLevelSlider"
                                        Width="120"
                                        Margin="8,0,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="False"
                                        SmallChange="1"
                                        LargeChange="10"
                                        VerticalAlignment="Center"
                                        ValueChanged="ObscurePixelationLevelSlider_ValueChanged" />
                                <TextBlock x:Name="ObscurePixelationLevelValueText"
                                           Margin="8,0,0,0"
                                           Foreground="{DynamicResource IslandMutedTextBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Text="0%" />
                            </StackPanel>
                            <StackPanel x:Name="ArrowOptionsPanel" Orientation="Horizontal" Margin="10,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                <Border Width="1" Height="24" Margin="0,0,10,0" Background="{DynamicResource IslandDividerBrush}" CornerRadius="1" />
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="Tail" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <Slider x:Name="ArrowTailSlider" Width="100" Minimum="0.15" Maximum="3.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="ArrowTailSlider_ValueChanged" ToolTip="Tail width" />
                                <TextBlock x:Name="ArrowTailValueLabel" Width="34" Margin="4,0,12,0" FontSize="11" Foreground="{DynamicResource IslandMutedTextBrush}" VerticalAlignment="Center" Text="1.0" />
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="Body" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <Slider x:Name="ArrowBodySlider" Width="100" Minimum="0.15" Maximum="3.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="ArrowBodySlider_ValueChanged" ToolTip="Body width" />
                                <TextBlock x:Name="ArrowBodyValueLabel" Width="34" Margin="4,0,12,0" FontSize="11" Foreground="{DynamicResource IslandMutedTextBrush}" VerticalAlignment="Center" Text="1.0" />
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="Front" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <Slider x:Name="ArrowFrontSlider" Width="100" Minimum="0.15" Maximum="3.0" SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="ArrowFrontSlider_ValueChanged" ToolTip="Front width" />
                                <TextBlock x:Name="ArrowFrontValueLabel" Width="34" Margin="4,0,12,0" FontSize="11" Foreground="{DynamicResource IslandMutedTextBrush}" VerticalAlignment="Center" Text="1.0" />
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="Head" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <Slider x:Name="ArrowHeadSlider" Width="100" Minimum="0.2" Maximum="1.6" SmallChange="0.05" LargeChange="0.2" TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="ArrowHeadSlider_ValueChanged" ToolTip="Head size" />
                                <TextBlock x:Name="ArrowHeadValueLabel" Width="34" Margin="4,0,0,0" FontSize="11" Foreground="{DynamicResource IslandMutedTextBrush}" VerticalAlignment="Center" Text="1.0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                <Border Width="1" Height="24" Margin="0,0,10,0" Background="{DynamicResource IslandDividerBrush}" CornerRadius="1" />
                                <Button Padding="12,8"
                                        Click="DeleteAnnotation_Click"
                                        Background="{DynamicResource DeleteButtonBackgroundBrush}"
                                        Foreground="{DynamicResource DeleteButtonForegroundBrush}"
                                        BorderBrush="{DynamicResource DeleteButtonBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Style="{StaticResource EditorGlyphStyle}" Text="&#xE74D;" />
                                        <TextBlock Style="{StaticResource EditorIconLabelStyle}" Text="Delete" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="EditorFooterPanel"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="18"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0">
                        <StackPanel HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                                <Border x:Name="CropActionsPanel"
                                        Style="{StaticResource FloatingCardStyle}"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="Crop" />
                                        <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource IslandMutedTextBrush}" Text="Draw a region and apply it to the current edit." TextWrapping="Wrap" />
                                        <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                            <Button x:Name="ApplyCropButton" Width="120" Click="ApplyCrop_Click" Style="{StaticResource EditorPrimaryButtonStyle}">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                    <TextBlock Style="{StaticResource EditorGlyphStackStyle}" Text="&#xE73E;" />
                                                    <TextBlock Style="{StaticResource EditorIconLabelCenteredStyle}" Text="Apply Crop" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="CancelCropButton" Width="104" Margin="10,0,0,0" Click="CancelCrop_Click" Style="{StaticResource EditorSecondaryButtonStyle}">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                    <TextBlock Style="{StaticResource EditorGlyphStackStyle}" Text="&#xE711;" />
                                                    <TextBlock Style="{StaticResource EditorIconLabelCenteredStyle}" Text="Cancel" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="UndoCropButton" Width="122" Margin="10,0,0,0" Click="UndoCrop_Click" Style="{StaticResource EditorSecondaryButtonStyle}">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                    <TextBlock Style="{StaticResource EditorGlyphStackStyle}" Text="&#xE7A7;" />
                                                    <TextBlock Style="{StaticResource EditorIconLabelCenteredStyle}" Text="Undo" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="UndoCropPanel"
                                        Margin="12,0,0,0"
                                        Style="{StaticResource FloatingCardStyle}"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="History" />
                                        <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource IslandMutedTextBrush}" Text="Undo the last edit, including crops, moves, style changes, and deleted objects." TextWrapping="Wrap" />
                                        <Button x:Name="UndoCropShortcutButton"
                                                Width="122"
                                                Margin="0,14,0,0"
                                                Click="UndoCrop_Click"
                                                Style="{StaticResource EditorSecondaryButtonStyle}">
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                <TextBlock Style="{StaticResource EditorGlyphStackStyle}" Text="&#xE7A7;" />
                                                <TextBlock Style="{StaticResource EditorIconLabelCenteredStyle}" Text="Undo" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Border x:Name="ToolbarIsland"
                                    Padding="10"
                                    Background="{DynamicResource IslandBackgroundBrush}"
                                    BorderBrush="{DynamicResource IslandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="26"
                                    Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="34" ShadowDepth="12" Color="#CC000000" Opacity="0.46" />
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TranslateTransform Y="18" />
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.28" />
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.32">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>

                                <DockPanel LastChildFill="False">
                                    <StackPanel Orientation="Horizontal">
                                        <ToggleButton x:Name="SelectToolButton" Style="{StaticResource EditorTopBarToolButtonStyle}" Checked="ToolButton_Checked" Tag="Select" ToolTip="Select">
                                            <Viewbox Width="18" Height="18">
                                                <Canvas Width="16" Height="16">
                                                    <Path Fill="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                          Data="M2,1 L10.4,8.1 L6.9,8.7 L8.9,13.9 L6.8,15 L4.8,9.7 L2,12.3 Z" />
                                                </Canvas>
                                            </Viewbox>
                                        </ToggleButton>
                                        <ToggleButton x:Name="CropToolButton" Margin="8,0,0,0" Style="{StaticResource EditorTopBarToolButtonStyle}" Checked="ToolButton_Checked" Tag="Crop" ToolTip="Crop">
                                            <Viewbox Width="18" Height="18">
                                                <Canvas Width="16" Height="16">
                                                    <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                          StrokeThickness="1.7"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Data="M4,1 V11 M1,4 H11 M12,5 V15 M5,12 H15" />
                                                </Canvas>
                                            </Viewbox>
                                        </ToggleButton>
                                        <ToggleButton x:Name="ArrowToolButton" Margin="8,0,0,0" Style="{StaticResource EditorTopBarToolButtonStyle}" Checked="ToolButton_Checked" Tag="Arrow" ToolTip="Arrow">
                                            <Viewbox Width="18" Height="18">
                                                <Canvas Width="16" Height="16">
                                                    <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                          StrokeThickness="1.7"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Data="M2,13 L13,2 M8.5,2 H13 V6.5" />
                                                </Canvas>
                                            </Viewbox>
                                        </ToggleButton>
                                        <Border Width="1" Height="26" Margin="14,9,14,9" Background="{DynamicResource IslandDividerBrush}" CornerRadius="1" />
                                        <ToggleButton x:Name="RectangleToolButton" Style="{StaticResource EditorTopBarToolButtonStyle}" Checked="ToolButton_Checked" Tag="Rectangle" ToolTip="Frame">
                                            <Viewbox Width="18" Height="18">
                                                <Canvas Width="16" Height="16">
                                                    <Rectangle Width="12" Height="9" Canvas.Left="2" Canvas.Top="3.5"
                                                               RadiusX="1"
                                                               RadiusY="1"
                                                               Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                               StrokeThickness="1.7" />
                                                </Canvas>
                                            </Viewbox>
                                        </ToggleButton>
                                        <ToggleButton x:Name="EllipseToolButton" Margin="8,0,0,0" Style="{StaticResource EditorTopBarToolButtonStyle}" Checked="ToolButton_Checked" Tag="Ellipse" ToolTip="Circle">
                                            <Viewbox Width="18" Height="18">
                                                <Canvas Width="16" Height="16">
                                                    <Ellipse Width="11" Height="11" Canvas.Left="2.5" Canvas.Top="2.5"
                                                             Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                             StrokeThickness="1.7" />
                                                </Canvas>
                                            </Viewbox>
                                        </ToggleButton>
                                        <ToggleButton x:Name="ObscureToolButton" Margin="8,0,0,0" Style="{StaticResource EditorTopBarToolButtonStyle}" Checked="ToolButton_Checked" Tag="Obscure" ToolTip="Obscure sensitive content">
                                            <Viewbox Width="18" Height="18">
                                                <Canvas Width="16" Height="16">
                                                    <Rectangle Width="11.5" Height="8.5" Canvas.Left="2.25" Canvas.Top="3.75"
                                                               RadiusX="1.6"
                                                               RadiusY="1.6"
                                                               Fill="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                               Opacity="0.16"
                                                               Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                               StrokeThickness="1.5" />
                                                    <Line X1="4" Y1="6.5" X2="12" Y2="6.5"
                                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                          StrokeThickness="1.2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeDashArray="1.2,1.1" />
                                                    <Line X1="4" Y1="9.5" X2="12" Y2="9.5"
                                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                          StrokeThickness="1.2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeDashArray="1.2,1.1" />
                                                    <Path Stroke="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                          StrokeThickness="1.7"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Data="M2.4,13.6 L13.6,2.4" />
                                                </Canvas>
                                            </Viewbox>
                                        </ToggleButton>
                                        <ToggleButton x:Name="TextToolButton" Margin="8,0,0,0" Style="{StaticResource EditorTopBarToolButtonStyle}" Checked="ToolButton_Checked" Tag="Text" ToolTip="Text">
                                            <TextBlock FontSize="18"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}"
                                                       Text="T" />
                                        </ToggleButton>
                                    </StackPanel>

                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="14,0,0,0">
                                        <Border Width="1" Height="26" Margin="0,9,14,9" Background="{DynamicResource IslandDividerBrush}" CornerRadius="1" />
                                        <Border Margin="0,0,8,0"
                                                Padding="12,0"
                                                Height="44"
                                                Background="{DynamicResource IslandButtonBrush}"
                                                BorderBrush="Transparent"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Style="{StaticResource EditorGlyphStyle}" FontSize="15" Margin="0,0,6,0" Text="&#xE91B;" />
                                                <TextBlock x:Name="ImageDimensionsText"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource IslandTextBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Text="0 x 0" />
                                            </StackPanel>
                                        </Border>
                                        <Button x:Name="UndoHistoryButton" Click="UndoHistory_Click" Style="{StaticResource EditorTopBarButtonStyle}" ToolTip="Undo (Ctrl+Z)">
                                            <TextBlock Style="{StaticResource EditorGlyphStyle}" FontSize="18" Margin="0" Text="&#xE7A7;" />
                                        </Button>
                                        <Button x:Name="RedoHistoryButton" Margin="8,0,0,0" Click="RedoHistory_Click" Style="{StaticResource EditorTopBarButtonStyle}" ToolTip="Redo (Ctrl+Y)">
                                            <TextBlock Style="{StaticResource EditorGlyphStyle}" FontSize="18" Margin="0" Text="&#xE7A6;" />
                                        </Button>
                                        <Button Margin="8,0,0,0" Click="Copy_Click" Style="{StaticResource EditorTopBarButtonStyle}" ToolTip="Copy">
                                            <TextBlock Style="{StaticResource EditorGlyphStyle}" FontSize="18" Margin="0" Text="&#xE8C8;" />
                                        </Button>
                                        <Button Margin="8,0,0,0" Click="Save_Click" Style="{StaticResource EditorTopBarButtonStyle}" ToolTip="Save">
                                            <TextBlock Style="{StaticResource EditorGlyphStyle}" FontSize="18" Margin="0" Text="&#xE74E;" />
                                        </Button>
                                        <Button Margin="8,0,0,0" Click="SaveAs_Click" Style="{StaticResource EditorTopBarPrimaryButtonStyle}" ToolTip="Save As">
                                            <TextBlock Style="{StaticResource EditorGlyphStyle}" FontSize="18" Margin="0" Text="&#xE74E;" />
                                        </Button>
                                        <Button x:Name="ThemeModeButton" Margin="8,0,0,0" Click="ThemeModeButton_Click" Style="{StaticResource EditorTopBarButtonStyle}" ToolTip="Theme: System">
                                            <Grid Width="18" Height="18">
                                                <Canvas x:Name="ThemeModeSystemIcon" Width="18" Height="18">
                                                    <Rectangle Width="13" Height="9" Canvas.Left="2.5" Canvas.Top="3"
                                                               RadiusX="1.5"
                                                               RadiusY="1.5"
                                                               Stroke="{DynamicResource IslandTextBrush}"
                                                               StrokeThickness="1.5" />
                                                    <Line X1="6.5" Y1="14.5" X2="11.5" Y2="14.5" Stroke="{DynamicResource IslandTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="9" Y1="12.2" X2="9" Y2="14.5" Stroke="{DynamicResource IslandTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                </Canvas>
                                                <Canvas x:Name="ThemeModeDarkIcon" Width="18" Height="18" Visibility="Collapsed">
                                                    <Path Fill="{DynamicResource IslandTextBrush}"
                                                          Data="M12.8,2.3 C10.7,2.6 9,4.5 9,6.8 C9,9.3 11,11.3 13.5,11.3 C14.3,11.3 15.1,11.1 15.8,10.7 C15,13.4 12.5,15.3 9.6,15.3 C6,15.3 3.1,12.4 3.1,8.8 C3.1,5.4 5.8,2.6 9.2,2.3 C10.4,2.2 11.7,2.2 12.8,2.3 Z" />
                                                </Canvas>
                                                <Canvas x:Name="ThemeModeLightIcon" Width="18" Height="18" Visibility="Collapsed">
                                                    <Ellipse Width="6" Height="6" Canvas.Left="6" Canvas.Top="6" Fill="{DynamicResource IslandTextBrush}" />
                                                    <Line X1="9" Y1="1.5" X2="9" Y2="4" Stroke="{DynamicResource IslandTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="9" Y1="14" X2="9" Y2="16.5" Stroke="{DynamicResource IslandTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="1.5" Y1="9" X2="4" Y2="9" Stroke="{DynamicResource IslandTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="14" Y1="9" X2="16.5" Y2="9" Stroke="{DynamicResource IslandTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="3.4" Y1="3.4" X2="5.1" Y2="5.1" Stroke="{DynamicResource IslandTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="12.9" Y1="12.9" X2="14.6" Y2="14.6" Stroke="{DynamicResource IslandTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="12.9" Y1="5.1" X2="14.6" Y2="3.4" Stroke="{DynamicResource IslandTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="3.4" Y1="14.6" X2="5.1" Y2="12.9" Stroke="{DynamicResource IslandTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                </Canvas>
                                            </Grid>
                                        </Button>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>