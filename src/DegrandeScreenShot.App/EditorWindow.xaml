<Window x:Class="DegrandeScreenShot.App.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Capture"
        Width="850"
        Height="400"
        MinWidth="850"
        MinHeight="400"
        Background="{DynamicResource ShellBackgroundBrush}"
        PreviewKeyDown="EditorWindow_PreviewKeyDown"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#1B2028" />
        <SolidColorBrush x:Key="EditorWorkspaceBrush" Color="#202630" />
        <SolidColorBrush x:Key="EditorCanvasBrush" Color="#2A3039" />
        <SolidColorBrush x:Key="IslandBackgroundBrush" Color="#D91A1E25" />
        <SolidColorBrush x:Key="IslandBorderBrush" Color="#28FFFFFF" />
        <SolidColorBrush x:Key="IslandButtonBrush" Color="#12FFFFFF" />
        <SolidColorBrush x:Key="IslandButtonHoverBrush" Color="#1CFFFFFF" />
        <SolidColorBrush x:Key="IslandButtonPressedBrush" Color="#26FFFFFF" />
        <SolidColorBrush x:Key="IslandButtonActiveBrush" Color="#FF1AA9D8" />
        <SolidColorBrush x:Key="IslandButtonActiveBorderBrush" Color="#7DCCF3FF" />
        <SolidColorBrush x:Key="IslandTextBrush" Color="#FFF4F7FB" />
        <SolidColorBrush x:Key="IslandMutedTextBrush" Color="#A9C2CEDA" />
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#FF1AA9D8" />
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#7DCCF3FF" />
        <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#FF34BCE6" />
        <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#FF1498C6" />
        <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#18FFFFFF" />
        <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#1FFFFFFF" />
        <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="SecondaryButtonPressedBrush" Color="#2BFFFFFF" />
        <SolidColorBrush x:Key="FloatingCardBrush" Color="#D9161A20" />
        <SolidColorBrush x:Key="FloatingCardBorderBrush" Color="#2BFFFFFF" />
        <SolidColorBrush x:Key="ShellScrimBrush" Color="#09000000" />
        <SolidColorBrush x:Key="ShellTopHighlightBrush" Color="#12FFFFFF" />
        <SolidColorBrush x:Key="InlineTextInputBackgroundBrush" Color="#D91A1E25" />
        <SolidColorBrush x:Key="InlineTextInputBorderBrush" Color="#66CCF3FF" />
        <SolidColorBrush x:Key="InlineTextInputForegroundBrush" Color="#FFF4F7FB" />
        <SolidColorBrush x:Key="PopupPanelBackgroundBrush" Color="#F0181C22" />
        <SolidColorBrush x:Key="PopupPanelBorderBrush" Color="#26FFFFFF" />
        <SolidColorBrush x:Key="DeleteButtonBackgroundBrush" Color="#3AD94841" />
        <SolidColorBrush x:Key="DeleteButtonBorderBrush" Color="#80FFB0AA" />
        <SolidColorBrush x:Key="DeleteButtonForegroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="IslandDividerBrush" Color="#1FFFFFFF" />
        <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#2B252C36" />
        <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#768693A2" />
        <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#9AA1ADBA" />
        <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#C0B7C3CF" />
        <SolidColorBrush x:Key="EditorSliderTrackBrush" Color="#30333A" />
        <SolidColorBrush x:Key="EditorSliderFillBrush" Color="#FF1AA9D8" />
        <SolidColorBrush x:Key="EditorSliderFillHoverBrush" Color="#FF34BCE6" />
        <SolidColorBrush x:Key="EditorSliderThumbBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="EditorSliderThumbBorderBrush" Color="#26000000" />
        <LinearGradientBrush x:Key="ShellGlowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#44FFB86C" Offset="0" />
            <GradientStop Color="#14FF7A00" Offset="0.4" />
            <GradientStop Color="#00000000" Offset="0.9" />
        </LinearGradientBrush>

        <Style x:Key="EditorPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#6600C8FF" Opacity="0.45" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Storyboard x:Key="ButtonGrowStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.18" />
                </Storyboard>
                <Storyboard x:Key="ButtonResetStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18" />
                </Storyboard>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryButtonPressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard Storyboard="{StaticResource ButtonGrowStoryboard}" />
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard Storyboard="{StaticResource ButtonResetStoryboard}" />
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource IslandTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SecondaryButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Storyboard x:Key="SecondaryButtonGrowStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.04" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.04" Duration="0:0:0.18" />
                </Storyboard>
                <Storyboard x:Key="SecondaryButtonResetStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18" />
                </Storyboard>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryButtonPressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard Storyboard="{StaticResource SecondaryButtonGrowStoryboard}" />
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard Storyboard="{StaticResource SecondaryButtonResetStoryboard}" />
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorTopBarButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorSecondaryButtonStyle}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource IslandButtonBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
            <Setter Property="Foreground" Value="{DynamicResource IslandTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IslandButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IslandButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorTopBarPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorTopBarButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource IslandButtonActiveBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource IslandButtonActiveBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="EditorDeleteIconButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource DeleteButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DeleteButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DeleteButtonForegroundBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DeleteButtonSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DeleteButtonSurface" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DeleteButtonSurface" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorTopBarToolButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="{DynamicResource IslandButtonBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource IslandTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="ToolTipService.InitialShowDelay" Value="250" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Storyboard x:Key="ToolGrowStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.08" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.08" Duration="0:0:0.18" />
                </Storyboard>
                <Storyboard x:Key="ToolResetStoryboard">
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18" />
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18" />
                </Storyboard>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IslandButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IslandButtonActiveBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource IslandButtonActiveBorderBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard Storyboard="{StaticResource ToolGrowStoryboard}" />
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard Storyboard="{StaticResource ToolResetStoryboard}" />
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorIconLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource IslandTextBrush}" />
        </Style>

        <Style x:Key="EditorGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}" />
        </Style>

        <Style x:Key="EditorGlyphStackStyle" TargetType="TextBlock" BasedOn="{StaticResource EditorGlyphStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="EditorIconLabelCenteredStyle" TargetType="TextBlock" BasedOn="{StaticResource EditorIconLabelStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="FloatingCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource FloatingCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FloatingCardBorderBrush}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Color="#99000000" Opacity="0.34" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorSliderTrackButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="{DynamicResource EditorSliderTrackBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="6"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorSliderFillButtonStyle" TargetType="RepeatButton" BasedOn="{StaticResource EditorSliderTrackButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource EditorSliderFillBrush}" />
        </Style>

        <Style x:Key="EditorSliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="ThumbSurface"
                                 Width="14"
                                 Height="14"
                                 Fill="{DynamicResource EditorSliderThumbBrush}"
                                 Stroke="{DynamicResource EditorSliderThumbBorderBrush}"
                                 StrokeThickness="1"
                                 SnapsToDevicePixels="True">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#99000000" Opacity="0.32" />
                            </Ellipse.Effect>
                        </Ellipse>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbSurface" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.08" ScaleY="1.08" CenterX="7" CenterY="7" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbSurface" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.12" ScaleY="1.12" CenterX="7" CenterY="7" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Foreground" Value="{DynamicResource EditorSliderFillBrush}" />
            <Setter Property="Background" Value="{DynamicResource EditorSliderTrackBrush}" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="24" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track"
                                   Height="18"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Style="{StaticResource EditorSliderFillButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Style="{StaticResource EditorSliderTrackButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource EditorSliderThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorScrollRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbSurface"
                                Margin="3"
                                Background="{DynamicResource ScrollBarThumbBrush}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbSurface" Property="Background" Value="{DynamicResource ScrollBarThumbHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbSurface" Property="Background" Value="{DynamicResource ScrollBarThumbPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Background" Value="{DynamicResource ScrollBarTrackBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="ScrollBarRoot"
                              Width="12"
                              Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="DecreaseButton"
                                                  Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource EditorScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource EditorScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="IncreaseButton"
                                                  Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource EditorScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="ScrollBarRoot" Property="Width" Value="Auto" />
                                <Setter TargetName="ScrollBarRoot" Property="Height" Value="12" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                <Setter TargetName="DecreaseButton" Property="Command" Value="{x:Static ScrollBar.PageLeftCommand}" />
                                <Setter TargetName="IncreaseButton" Property="Command" Value="{x:Static ScrollBar.PageRightCommand}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ScrollBarTrackBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="12" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="EditorRootGrid" Background="{DynamicResource ShellBackgroundBrush}">
        <Rectangle Fill="{DynamicResource ShellGlowBrush}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Top"
                   Height="260"
                   IsHitTestVisible="False"
                   Opacity="0.95" />

        <Border Margin="0"
                Padding="0"
                CornerRadius="0"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#CC000000" Opacity="0.5" />
            </Border.Effect>

            <Border CornerRadius="0"
                    Background="{DynamicResource EditorWorkspaceBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    SnapsToDevicePixels="True">
                <Grid ClipToBounds="False">
                    <Rectangle Fill="{DynamicResource ShellScrimBrush}" IsHitTestVisible="False" />
                    <Rectangle Fill="{DynamicResource ShellTopHighlightBrush}"
                               Height="140"
                               VerticalAlignment="Top"
                               IsHitTestVisible="False">
                        <Rectangle.OpacityMask>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFFFFFFF" Offset="0" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.OpacityMask>
                    </Rectangle>

                    <ScrollViewer x:Name="ArtworkScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent"
                                  PreviewMouseWheel="ArtworkScrollViewer_PreviewMouseWheel"
                                  ScrollChanged="ArtworkScrollViewer_ScrollChanged">
                        <Grid MinWidth="{Binding ElementName=ArtworkScrollViewer, Path=ViewportWidth}"
                              MinHeight="{Binding ElementName=ArtworkScrollViewer, Path=ViewportHeight}">
                            <Border Margin="0,80,0,136"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CornerRadius="0">
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
