                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                                <Border x:Name="CropActionsPanel"
                                        Style="{StaticResource FloatingCardStyle}"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource IslandTextBrush}" Text="Crop" />
                                        <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource IslandMutedTextBrush}" Text="Draw a region and apply it to the current edit." TextWrapping="Wrap" />
                                        <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                            <Button x:Name="ApplyCropButton" Width="120" Click="ApplyCrop_Click" Style="{StaticResource EditorPrimaryButtonStyle}">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                    <TextBlock Style="{StaticResource EditorGlyphStackStyle}" Text="&#xE73E;" />
