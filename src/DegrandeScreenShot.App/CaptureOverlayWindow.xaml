<Window x:Class="DegrandeScreenShot.App.CaptureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
    Cursor="Cross"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True"
        WindowStartupLocation="Manual"
        Title="Capture Overlay">
    <Grid>
        <Canvas x:Name="OverlayCanvas" Background="Transparent">
            <Image x:Name="FrozenDesktopImage" Stretch="None" IsHitTestVisible="False" />
            <Rectangle x:Name="TopShade" Fill="{StaticResource OverlayDimBrush}" IsHitTestVisible="False" />
            <Rectangle x:Name="LeftShade" Fill="{StaticResource OverlayDimBrush}" IsHitTestVisible="False" />
            <Rectangle x:Name="RightShade" Fill="{StaticResource OverlayDimBrush}" IsHitTestVisible="False" />
            <Rectangle x:Name="BottomShade" Fill="{StaticResource OverlayDimBrush}" IsHitTestVisible="False" />

            <Rectangle x:Name="SelectionBorder" Stroke="{StaticResource SelectionStrokeBrush}" StrokeThickness="2" RadiusX="3" RadiusY="3" Visibility="Collapsed" IsHitTestVisible="False" />

                <Border x:Name="SelectionInfoPanel"
                    Padding="10,6"
                    Background="#DD131921"
                    BorderBrush="#661AA9D8"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <TextBlock x:Name="SelectionInfoText"
                       Foreground="White"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Text="0 x 0" />
                </Border>

            <Border x:Name="HintPanel"
                    Width="320"
                    Padding="16"
                    Background="#CC131921"
                    CornerRadius="18"
                    IsHitTestVisible="False">
                <StackPanel>
                    <TextBlock x:Name="HintTitleText" Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Select a region" />
                    <TextBlock x:Name="HintDescriptionText" Margin="0,8,0,0" Foreground="#FFD4E5ED" Text="Drag to select. Hold Shift for 1:1, Ctrl to move the frame, arrows to nudge 1 px, Esc to cancel." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border x:Name="ActionPanel"
                    Width="240"
                    Padding="14"
                    Background="#F4F4F8FB"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="What next?" />
                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                        <Button Width="98" Click="CopyButton_Click" Style="{StaticResource PrimaryButtonStyle}" Content="Copy" />
                        <Button Width="98" Margin="12,0,0,0" Click="EditButton_Click" Style="{StaticResource SecondaryButtonStyle}" Content="Edit" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>