<Window x:Class="DegrandeScreenShot.App.CaptureCountdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delayed Capture"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        IsHitTestVisible="False">
    <Grid Margin="18">
        <Border Padding="20,14"
                Background="#E91A1E25"
                BorderBrush="#4DFFFFFF"
                BorderThickness="1"
                CornerRadius="22">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Color="#CC000000" Opacity="0.46" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="48" Height="48" Background="#FF1AA9D8" CornerRadius="24">
                    <TextBlock x:Name="SecondsText"
                               Text="3"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Delayed capture"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Position the pointer now"
                               Margin="0,3,0,0"
                               Foreground="#C8D7E2EB"
                               FontSize="11" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
