<Window x:Class="DegrandeScreenShot.App.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Software Update"
        Width="480"
        Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <!-- Modern ProgressBar template matching the launcher style -->
        <Style x:Key="ModernProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="10" />
            <Setter Property="Background" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" />
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="5" Background="{DynamicResource AccentBrush}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Outer Card Container -->
        <Border Margin="12"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1.5"
                CornerRadius="24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="6" Color="#2A000000" Opacity="0.3" />
            </Border.Effect>
            
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <!-- Header Banner Card (similar to launcher hero banner) -->
                    <RowDefinition Height="Auto" />
                    <!-- Version comparison text -->
                    <RowDefinition Height="Auto" />
                    <!-- Release Notes Panel -->
                    <RowDefinition Height="*" />
                    <!-- Download progress area (hidden by default) -->
                    <RowDefinition Height="Auto" />
                    <!-- Footer action buttons -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 1. Header Banner -->
                <Border Grid.Row="0"
                        Padding="18"
                        Background="{DynamicResource HeroBrush}"
                        CornerRadius="18"
                        MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel>
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource HeroMutedBrush}" Text="SOFTWARE UPDATE" />
                            <TextBlock Margin="0,4,0,0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource HeroTextBrush}" Text="Update Available!" />
                        </StackPanel>
                        
                        <!-- Translucent Circular Close button -->
                        <Button Grid.Column="1"
                                Width="30"
                                Height="30"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right"
                                Click="CloseButton_Click"
                                Cursor="Hand"
                                Background="{DynamicResource CloseButtonBrush}"
                                BorderBrush="{DynamicResource CloseButtonBorderBrush}"
                                BorderThickness="1.2"
                                Foreground="White"
                                Content="✕"
                                FontSize="12"
                                FontWeight="Bold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="15">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- 2. Version Info -->
                <TextBlock Grid.Row="1"
                           x:Name="VersionInfoTextBlock"
                           Margin="4,14,4,0"
                           FontSize="13.5"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           TextWrapping="Wrap"
                           Text="Version 0.0.0 is now available (you have 0.0.0)." />

                <!-- 3. Release Notes Rich Text Viewer -->
                <Border Grid.Row="2"
                        Margin="0,12,0,0"
                        Background="{DynamicResource AppBackgroundBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="12,10">
                    <FlowDocumentScrollViewer x:Name="ReleaseNotesViewer"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Margin="0"
                                              Padding="0"
                                              Focusable="False">
                        <FlowDocument Background="Transparent"
                                      FontFamily="Segoe UI Variable Text, Segoe UI, Roboto"
                                      FontSize="13"
                                      Foreground="{DynamicResource TextBrush}">
                            <Paragraph>
                                <Run Text="Loading release details..." />
                            </Paragraph>
                        </FlowDocument>
                    </FlowDocumentScrollViewer>
                </Border>

                <!-- 4. Download Progress Area -->
                <StackPanel Grid.Row="3" x:Name="ProgressArea" Margin="4,12,4,0" Visibility="Collapsed">
                    <Grid>
                        <TextBlock x:Name="StatusTextBlock" FontSize="12.5" Foreground="{DynamicResource TextBrush}" Text="Downloading..." />
                        <TextBlock x:Name="PercentageTextBlock" HorizontalAlignment="Right" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" Text="0%" />
                    </Grid>
                    <ProgressBar x:Name="DownloadProgressBar"
                                 Margin="0,6,0,0"
                                 Value="0"
                                 Maximum="100"
                                 Style="{DynamicResource ModernProgressBarStyle}" />
                </StackPanel>

                <!-- 5. Actions Footer -->
                <Grid Grid.Row="4" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="LaterButton"
                            Grid.Column="0"
                            Margin="0,0,6,0"
                            Height="38"
                            Click="CloseButton_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Later" />
                    
                    <Button x:Name="UpdateNowButton"
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            Height="38"
                            Click="UpdateNowButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Update Now" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
